<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Coming Soon</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background-color: #f0f5f9; /* Light blue */
      margin: 0;
      padding: 0;
    }

    .container {
      text-align: center;
      margin-top: 50px; /* Adjust top margin as needed */
    }

    h1 {
      color: #6c5b7b; /* Purple */
      font-size: 48px;
      margin-bottom: 20px;
    }

    p {
      color: #355c7d; /* Blue */
      font-size: 24px;
    }

    .menu {
      padding: 10px;
      text-align: center;
      display: inline-block; /* Set display to inline-block */
    }

    .menu ul {
      list-style: none;
      margin: 0;
      padding: 0;
      float: none;
      position: absolute;
      top: 5%;
      left: 50%;
      transform: translate(-50%, -50%);
    }

    .menu li {
      display: inline-block;
      margin-right: 10px;
    }

    .menu a {
      background-color: #f0f0f0;
      text-decoration: none;
      padding: 5px 10px;
      border-radius: 5px;
      transition: background-color 0.3s ease;
    }
    .menu a:hover {
      background-color: #d8d8d8;
    }
  </style>
</head>
<body>
  <div class="menu">
    <ul>
      <li><a href="#" class="nav-centered">Option 1</a></li>
      <li><a href="#" class="nav-centered">Option 2</a></li>
      <li><a href="#" class="nav-centered">Option 3</a></li>
      <li><a href="#" class="nav-centered">Option 4</a></li>
    </ul>
  </div>
  <div class="container">
    <h1>Coming Soon...</h1>
    <p>We're working on something awesome. Stay tuned!</p>
  </div>
</body>
</html>
